{
  "name": "digital-project-office",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "env:sync": "node scripts/generate-runtime-env.mjs",
    "start": "DPO_ENV_FILE=.env npm run env:sync && ng serve",
    "start:test": "DPO_ENV_FILE=.env.test npm run env:sync && ng serve",
    "start:windows": "cross-env DPO_ENV_FILE=.env npm run env:sync && ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "jest --runInBand --passWithNoTests",
    "test:watch": "jest --watch",
    "lint": "ng lint",
    "cypress:open": "cypress open",
    "cypress:run": "node scripts/run-cypress-with-mock.mjs",
    "cypress:run:raw": "cypress run",
    "mock:server": "DPO_ENV_FILE=.env node mock-server/server.js",
    "mock:server:test": "DPO_ENV_FILE=.env.test node mock-server/server.js",
    "mock:check": "node mock-server/check.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^19.2.19",
    "@angular/common": "^19.2.0",
    "@angular/compiler": "^19.2.0",
    "@angular/core": "^19.2.0",
    "@angular/forms": "^19.2.0",
    "@angular/platform-browser": "^19.2.0",
    "@angular/platform-browser-dynamic": "^19.2.0",
    "@angular/router": "^19.2.0",
    "chart.js": "^4.5.1",
    "date-fns": "^4.1.0",
    "lucide-angular": "^1.0.0",
    "multer": "^2.1.1",
    "ng2-charts": "^8.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.23",
    "@angular-eslint/builder": "^19.2.0",
    "@angular-eslint/eslint-plugin": "^19.2.0",
    "@angular-eslint/eslint-plugin-template": "^19.2.0",
    "@angular-eslint/template-parser": "^19.2.0",
    "@angular/cli": "^19.2.23",
    "@angular/compiler-cli": "^19.2.0",
    "@types/jasmine": "~5.1.0",
    "@types/jest": "^29.5.14",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "cypress": "^14.5.4",
    "eslint": "^9.39.4",
    "express": "^5.2.1",
    "jasmine-core": "~5.6.0",
    "jest": "^29.7.0",
    "jest-preset-angular": "^14.6.2",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "~5.7.2"
  }
}
